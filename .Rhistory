plot_dimension_on_pseudotime <- function(
X,
pt,
env_idx,
color_by = c("pseudotime", "mutant_type", "none"),
mutant_type = NULL,
S = NULL,
env_names = colnames(X),
interval_mult = 2,
point_alpha = 0.7,
point_size = 1.6,
interval_alpha = 0.25,
interval_width = 0,
title = NULL
) {
color_by <- match.arg(color_by)
if (!requireNamespace("ggplot2", quietly = TRUE)) {
stop("Package 'ggplot2' is required.")
}
X <- as.matrix(X)
if (length(pt) != nrow(X)) {
stop("'pt' must have length nrow(X).")
}
if (length(env_idx) < 1) {
stop("'env_idx' must contain at least one column index.")
}
X_sub <- X[, env_idx, drop = FALSE]
n <- nrow(X_sub)
m <- ncol(X_sub)
if (is.null(env_names)) {
env_names <- paste0("V", seq_len(ncol(X)))
}
env_names_sub <- env_names[env_idx]
df <- data.frame(
pseudotime = rep(pt, times = m),
value = as.vector(X_sub),
env = rep(env_names_sub, each = n)
)
if (!is.null(S)) {
S <- as.matrix(S)
if (!all(dim(S) == dim(X))) {
stop("'S' must have the same dimensions as 'X'.")
}
S_sub <- S[, env_idx, drop = FALSE]
se_vec <- as.vector(S_sub)
df$ymin <- df$value - interval_mult * se_vec
df$ymax <- df$value + interval_mult * se_vec
}
if (color_by == "pseudotime") {
df$color_var <- df$pseudotime
color_mapping <- ggplot2::aes(color = color_var)
color_scale <- ggplot2::scale_color_viridis_c(name = "Pseudotime")
} else if (color_by == "mutant_type") {
if (is.null(mutant_type)) {
stop("Please provide 'mutant_type' when color_by = 'mutant_type'.")
}
if (length(mutant_type) != nrow(X)) {
stop("'mutant_type' must have length nrow(X).")
}
df$color_var <- rep(mutant_type, times = m)
color_mapping <- ggplot2::aes(color = color_var)
color_scale <- ggplot2::scale_color_discrete(name = "Mutant type")
} else {
color_mapping <- NULL
color_scale <- NULL
}
if (is.null(title)) {
title <- "Dimension plot on pseudotime"
}
p <- ggplot2::ggplot(df, ggplot2::aes(x = pseudotime, y = value))
if (!is.null(S)) {
p <- p +
ggplot2::geom_linerange(
ggplot2::aes(ymin = ymin, ymax = ymax),
alpha = interval_alpha,
linewidth = 0.25
)
}
if (color_by == "none") {
p <- p +
ggplot2::geom_point(alpha = point_alpha, size = point_size)
} else {
p <- p +
ggplot2::geom_point(
color_mapping,
alpha = point_alpha,
size = point_size
) +
color_scale
}
p +
ggplot2::facet_wrap(~ env, scales = "free_y") +
ggplot2::labs(
title = title,
x = "Pseudotime",
y = "Observed value"
) +
ggplot2::theme_bw()
}
if (requireNamespace("MPCurver", quietly = TRUE)) {
library(MPCurver)
} else if (requireNamespace("devtools", quietly = TRUE)) {
devtools::load_all(".", quiet = TRUE)
} else {
stop("Need either an installed MPCurver package or devtools::load_all().")
}
set.seed(42)
locate_elife_csv <- function() {
pkg_path <- system.file("extdata", "elife-61271-fig2-data1-v2.csv", package = "MPCurver")
if (nzchar(pkg_path) && file.exists(pkg_path)) {
return(pkg_path)
}
src_path <- file.path("inst", "extdata", "elife-61271-fig2-data1-v2.csv")
if (file.exists(src_path)) {
return(src_path)
}
stop("Could not locate elife-61271-fig2-data1-v2.csv.")
}
csv_path <- locate_elife_csv()
dat <- read.csv(csv_path, check.names = FALSE)
fitness_cols <- grep("_fitness$", names(dat), value = TRUE)
error_cols <- grep("_error$", names(dat), value = TRUE)
X <- as.matrix(dat[, fitness_cols, drop = FALSE])
mode(X) <- "numeric"
colnames(X) <- sub("_fitness$", "", fitness_cols)
S <- as.matrix(dat[, error_cols, drop = FALSE])
mode(S) <- "numeric"
colnames(S) <- sub("_error$", "", error_cols)
meta <- dat[, c("barcode", "gene", "type", "ploidy", "class", "mutation_type"), drop = FALSE]
t_adjust_se <- function(Y, S, nu, tol = 1e-12) {
if (!is.matrix(Y) || !is.numeric(Y)) {
stop("`Y` must be a numeric matrix.")
}
if (!is.matrix(S) || !is.numeric(S)) {
stop("`S` must be a numeric matrix.")
}
if (!all(dim(Y) == dim(S))) {
stop("`Y` and `S` must have the same dimensions.")
}
if (any(S < 0, na.rm = TRUE)) {
stop("`S` must be nonnegative.")
}
if (length(nu) == 1L) {
if (!is.numeric(nu) || is.na(nu) || nu <= 0) {
stop("`nu` must be a positive number.")
}
nu_mat <- matrix(nu, nrow = nrow(Y), ncol = ncol(Y))
} else {
if (!is.matrix(nu) || !is.numeric(nu) || !all(dim(nu) == dim(Y))) {
stop("`nu` must be either a positive scalar or a numeric matrix with the same dimensions as `Y`.")
}
if (any(nu <= 0, na.rm = TRUE)) {
stop("All entries of `nu` must be positive.")
}
nu_mat <- nu
}
z_t <- Y / S
# Main calculation:
# S_tilde = S * z_t / qnorm(pt(z_t, df = nu))
p_t <- pt(z_t, df = nu_mat)
z_n <- qnorm(p_t)
S_tilde <- S * z_t / z_n
# Numerical fix for z_t close to 0:
# limit of z / qnorm(pt(z, df=nu)) as z -> 0 is dnorm(0) / dt(0, df=nu)
near_zero <- is.finite(z_t) & abs(z_t) < tol
if (any(near_zero, na.rm = TRUE)) {
limit_factor <- dnorm(0) / dt(0, df = nu_mat[near_zero])
S_tilde[near_zero] <- S[near_zero] * limit_factor
}
# Preserve zeros
zero_se <- (S == 0) & !is.na(S)
if (any(zero_se)) {
S_tilde[zero_se] <- 0
}
dimnames(S_tilde) <- dimnames(S)
S_tilde
}
# S <- t_adjust_se(X, S, nu = 4)
